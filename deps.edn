{:paths ["src" "resources"]

 :deps {org.clojure/clojure          {:mvn/version "1.12.0"}
        hato/hato                    {:mvn/version "1.0.0"}
        metosin/jsonista             {:mvn/version "0.3.12"}
        org.clojure/core.async       {:mvn/version "1.8.741"}
        ring/ring-jetty-adapter      {:mvn/version "1.12.2"}
        metosin/reitit-ring          {:mvn/version "0.7.2"}
        metosin/reitit-malli         {:mvn/version "0.7.2"}
        metosin/reitit-middleware    {:mvn/version "0.7.2"}
        hiccup/hiccup                {:mvn/version "2.0.0"}
        com.stuartsierra/component   {:mvn/version "1.1.0"}
        metosin/malli                {:mvn/version "0.20.1"}}

 :aliases
 {:test  {:extra-paths ["test"]
          :extra-deps  {io.github.cognitect-labs/test-runner
                        {:git/url "https://github.com/cognitect-labs/test-runner"
                         :git/sha "3f288f1f16d167723ad87cc35b1dfee3c1681e10"}
                        org.clojure/test.check {:mvn/version "1.1.3"}}
          :exec-fn     cognitect.test-runner.api/test}

  :serve {:main-opts ["-m" "openrouter.main"]}

  :dev   {:extra-paths ["dev" "test"]
          :extra-deps  {org.clojure/tools.namespace {:mvn/version "1.5.0"}}
          :main-opts   ["-r"]}}}
